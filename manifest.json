{
  "manifest_version": 3,
  "name": "Quest Tasks — Notion Reminder",
  "version": "0.4.0",
  "description": "เปลี่ยนสิ่งที่ต้องทำใน Notion ให้เป็น quest ที่อยากเคลียร์ เด้งเตือนตามวันที่กำหนด",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "contextMenus"
  ],
  "host_permissions": [
    "https://api.notion.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_title": "Quest Tasks",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
